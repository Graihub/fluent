TeleportSection:AddToggle({
    Title = "🚀 Teleport to Island",
    Default = false,
    Callback = function(value)
        if value and _G.SelectedIsland then
            local target = workspace._WorldOrigin.Locations:FindFirstChild(_G.SelectedIsland)
            if target then
                _tp(target.CFrame * CFrame.new(0, 50, 0))
                task.wait(2)
                _G.Teleport = false
            end
        end
    end
})

--====================
-- INITIALIZE SAVE MANAGER
--====================
SaveManager:SetLibrary(Fluent)
InterfaceManager:SetLibrary(Fluent)

InterfaceManager:SetFolder("TurboLiteHub")
SaveManager:SetFolder("TurboLiteHub/configs")

InterfaceManager:BuildInterfaceSection(Tabs.Settings)
SaveManager:BuildConfigSection(Tabs.Settings)

-- Auto-load config
task.wait(1)
SaveManager:LoadAutoloadConfig()

print("Turbo Lite Hub - Fluent Edition loaded!")
