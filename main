--====================
-- G KILL MODULE
--====================
local G = {}
G.__index = G

G.Alive = function(entity)
    if not entity then return end
    local humanoid = entity:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

_G.MobHeight = _G.MobHeight or 30

G.Kill = function(entity, isActive)
    if not (entity and isActive) then return end
    local hrp = entity:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not entity:GetAttribute("Locked") then
        entity:SetAttribute("Locked", hrp.CFrame)
    end
    PosMon = (entity:GetAttribute("Locked")).Position
    _B = true
    BringEnemy()
    EquipWeapon(_G.SelectWeapon)
    _tp(hrp.CFrame * CFrame.new(0, _G.MobHeight, 0))
end

G.Kill2 = function(entity, isActive)
    if entity and isActive then
        if not entity:GetAttribute("Locked") then
            entity:SetAttribute("Locked", entity.HumanoidRootPart.CFrame)
        end
        PosMon = (entity:GetAttribute("Locked")).Position
        BringEnemy()
        EquipWeapon(_G.SelectWeapon)
        local tool = plr.Character:FindFirstChildOfClass("Tool")
        if tool and tool.ToolTip == "Blox Fruit" then
            _tp((entity.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)) * CFrame.Angles(0, math.rad(90), 0))
        else
            _tp((entity.HumanoidRootPart.CFrame * CFrame.new(0, 20, 8)) * CFrame.Angles(0, math.rad(180), 0))
        end
    end
end

G.Sword = function(entity, isActive)
    if entity and isActive then
        if not entity:GetAttribute("Locked") then
            entity:SetAttribute("Locked", entity.HumanoidRootPart.CFrame)
        end
        PosMon = (entity:GetAttribute("Locked")).Position
        BringEnemy()
        weaponSc("Sword")
        _tp(entity.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
    end
end

G.Mas = function(entity, isActive)
    if entity and isActive then
        if not entity:GetAttribute("Locked") then
            entity:SetAttribute("Locked", entity.HumanoidRootPart.CFrame)
        end
        PosMon = (entity:GetAttribute("Locked")).Position
        BringEnemy()
        if entity.Humanoid.Health <= HealthM then
            _tp(entity.HumanoidRootPart.CFrame * CFrame.new(0, 20, 0))
            UseFruitSkills()
        else
            weaponSc("Melee")
            _tp(entity.HumanoidRootPart.CFrame * CFrame.new(0, 30, 0))
        end
    end
end

-- Fruit skills
_G.FruitSkills = { Z = false, X = false, C = false, V = false, F = false }

UseFruitSkills = function()
    weaponSc("Blox Fruit")
    if _G.FruitSkills.Z then Useskills("Blox Fruit", "Z") end
    if _G.FruitSkills.X then Useskills("Blox Fruit", "X") end
    if _G.FruitSkills.C then Useskills("Blox Fruit", "C") end
    if _G.FruitSkills.V then Useskills("Blox Fruit", "V") end
    if _G.FruitSkills.F then 
        VirtualInputManager:SendKeyEvent(true, "F", false, game)
        VirtualInputManager:SendKeyEvent(false, "F", false, game)
    end
end

Useskills = function(weaponType, skillKey)
    if weaponType == "Melee" then
        weaponSc("Melee")
        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
    elseif weaponType == "Sword" then
        weaponSc("Sword")
        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
    elseif weaponType == "Blox Fruit" then
        weaponSc("Blox Fruit")
        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
    elseif weaponType == "Gun" then
        weaponSc("Gun")
        VirtualInputManager:SendKeyEvent(true, skillKey, false, game)
        VirtualInputManager:SendKeyEvent(false, skillKey, false, game)
    elseif weaponType == "nil" and skillKey == "Y" then
        VirtualInputManager:SendKeyEvent(true, "Y", false, game)
        VirtualInputManager:SendKeyEvent(false, "Y", false, game)
    end
end

--====================
-- BRING SYSTEM
--====================
_B = false
PosMon = nil
_G.BringRange = _G.BringRange or 250
_G.MaxBringMobs = _G.MaxBringMobs or 15

local TweenInfoBring = TweenInfo.new(0.50, Enum.EasingStyle.Linear)

local function IsRaidMob(mob)
    local name = mob.Name:lower()
    if name:find("raid") or name:find("microchip") or name:find("island") then return true end
    if mob:GetAttribute("IsRaid") or mob:GetAttribute("RaidMob") or mob:GetAttribute("IsBoss") then return true end
    local hum = mob:FindFirstChild("Humanoid")
    if hum and hum.WalkSpeed == 0 then return true end
    return false
end

BringEnemy = function()
    if not _G.StartFarm or not _B then return end
    local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function() sethiddenproperty(plr, "SimulationRadius", math.huge) end)
    local targetPos = PosMon or hrp.Position
    local count = 0
    for _, mob in ipairs(workspace.Enemies:GetChildren()) do
        if count >= _G.MaxBringMobs then break end
        local hum = mob:FindFirstChild("Humanoid")
        local root = mob:FindFirstChild("HumanoidRootPart")
        if hum and root and hum.Health > 0 and not IsRaidMob(mob) then
            local dist = (root.Position - targetPos).Magnitude
            if dist <= _G.BringRange and not root:GetAttribute("Tweening") then
                count += 2
                root:SetAttribute("Tweening", true)
                local tween = TweenService:Create(root, TweenInfoBring, { CFrame = CFrame.new(targetPos) })
                tween:Play()
                tween.Completed:Once(function()
                    if root then root:SetAttribute("Tweening", false) end
                end)
            end
        end
    end
end

task.spawn(function()
    while task.wait(1) do
        if _G.StartFarm then
            _B = true
            BringEnemy()
            task.wait(1)
            _B = false
            task.wait(1)
        else
            _B = false
            task.wait(1)
        end
    end
end)

--====================
-- TWEEN SYSTEM
--====================
getgenv().TweenSpeedFar = 370
getgenv().TweenSpeedNear = 370

local C = Instance.new("Part", workspace)
C.Size = Vector3.new(1, 1, 1)
C.Name = "Rip_Indra"
C.Anchored = true
C.CanCollide = false
C.CanTouch = false
C.Transparency = 1

task.spawn(function()
    while task.wait() do
        if C and C.Parent == workspace then
            getgenv().OnFarm = shouldTween
        else
            getgenv().OnFarm = false
        end
    end
end)

task.spawn(function()
    repeat task.wait() until plr.Character and plr.Character.PrimaryPart
    C.CFrame = plr.Character.PrimaryPart.CFrame
    while task.wait() do
        pcall(function()
            if getgenv().OnFarm then
                if C and C.Parent == workspace then
                    local hrp = plr.Character and plr.Character.PrimaryPart
                    if hrp and (hrp.Position - C.Position).Magnitude <= 200 then
                        hrp.CFrame = C.CFrame
                    else
                        C.CFrame = hrp.CFrame
                    end
                end
                if plr.Character then
                    for _, v in pairs(plr.Character:GetChildren()) do
                        if v:IsA("BasePart") then v.CanCollide = false end
                    end
                end
            else
                if plr.Character then
                    for _, v in pairs(plr.Character:GetChildren()) do
                        if v:IsA("BasePart") then v.CanCollide = true end
                    end
                end
            end
        end)
    end
end)

_tp = function(targetCFrame)
    local char = plr.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local HRP = char.HumanoidRootPart
    shouldTween = true
    getgenv().OnFarm = false
    if HRP.Anchored then HRP.Anchored = false task.wait() end
    local dist = (targetCFrame.Position - HRP.Position).Magnitude
    local speed = dist <= 15 and getgenv().TweenSpeedNear or getgenv().TweenSpeedFar
    local info = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(C, info, { CFrame = targetCFrame })
    if char.Humanoid.Sit then C.CFrame = CFrame.new(C.Position.X, targetCFrame.Y, C.Position.Z) end
    tween:Play()
    task.spawn(function()
        while tween.PlaybackState == Enum.PlaybackState.Playing do
            if not shouldTween then tween:Cancel() break end
            task.wait(.1)
        end
        getgenv().OnFarm = true
    end)
end

notween = function(targetCFrame)
    plr.Character.HumanoidRootPart.CFrame = targetCFrame
end

