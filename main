    Title = "🚀 Auto Travel",
    Default = false,
    Callback = function(value)
        _G.Teleport = value
        if value and _G.SelectedIsland then
            local target = workspace._WorldOrigin.Locations:FindFirstChild(_G.SelectedIsland)
            if target then
                _tp(target.CFrame * CFrame.new(0, 50, 0))
                task.wait(2)
                _G.Teleport = false
            end
        end
    end
})

-- Portal teleport
TeleportSection = Tabs.Teleport:AddSection("Portal Teleport")

local portals = {}
if World1 then portals = {"Sky", "UnderWater"}
elseif World2 then portals = {"SwanRoom", "Cursed Ship"}
elseif World3 then portals = {"Castle On The Sea", "Mansion Cafe", "Hydra Teleport", "Canvendish Room", "Temple of Time"} end

local portalCoords = {
    Sky = Vector3.new(-7894, 5547, -380), UnderWater = Vector3.new(61163, 11, 1819),
    SwanRoom = Vector3.new(2285, 15, 905), ["Cursed Ship"] = Vector3.new(923, 126, 32852),
    ["Castle On The Sea"] = Vector3.new(-5097.93164, 316.447021, -3142.66602),
    ["Mansion Cafe"] = Vector3.new(-12471.169921875, 374.94024658203, -7551.677734375),
    ["Hydra Teleport"] = Vector3.new(5643.4526367188, 1013.0858154297, -340.51025390625),
    ["Canvendish Room"] = Vector3.new(5314.5463867188, 22.562219619751, -127.06755065918),
    ["Temple of Time"] = Vector3.new(28310.0234, 14895.1123, 109.456741)
}

TeleportSection:AddDropdown({
    Title = "🚪 Select Portal",
    Values = portals,
    Callback = function(value) _G.SelectedPortal = value end
})

TeleportSection:AddButton({
    Title = "✨ Enter Portal",
    Callback = function()
        if _G.SelectedPortal and portalCoords[_G.SelectedPortal] then
            commF:InvokeServer("requestEntrance", portalCoords[_G.SelectedPortal])
        end
    end
})

