    while task.wait(1) do
        pcall(function()
            if player.Data.Points.Value > 0 then
                if _G.Auto_Melee then commF:InvokeServer("AddPoint", "Melee", 1) end
                if _G.Auto_Defense then commF:InvokeServer("AddPoint", "Defense", 1) end
                if _G.Auto_Sword then commF:InvokeServer("AddPoint", "Sword", 1) end
                if _G.Auto_Gun then commF:InvokeServer("AddPoint", "Gun", 1) end
                if _G.Auto_DevilFruit then commF:InvokeServer("AddPoint", "Demon Fruit", 1) end
            end
        end)
    end
end)

