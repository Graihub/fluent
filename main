    Default = GetSetting("StartFarm_Save", false),
    Callback = function(value)
        _G.StartFarm = value
        _G.Level = false
        _G.AutoFarm_Bone = false
        _G.AutoFarm_Cake = false
        _G.AutoTyrant = false
        _G.AutoFactory = false
        _G.AutoRaidCastle = false

        if value then
            if _G.SelectedFarmMode == "Level" then
                _G.Level = true
            elseif _G.SelectedFarmMode == "Bone" then
                _G.AutoFarm_Bone = true
            elseif _G.SelectedFarmMode == "Cake Prince" then
                _G.AutoFarm_Cake = true
            elseif _G.SelectedFarmMode == "Tyrant" then
                _G.AutoTyrant = true
            elseif _G.SelectedFarmMode == "Factory" then
                _G.AutoFactory = true
            elseif _G.SelectedFarmMode == "Pirate Raid" then
                _G.AutoRaidCastle = true
            end
        end

        _G.SaveData["StartFarm_Save"] = value
        SaveSettings()
    end
})

