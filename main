-- Boss Farm
StackSection = Tabs.Stack:AddSection("Boss Farm")

local BossDropdown = StackSection:AddDropdown({
    Title = "👾 Select Boss",
    Values = Boss,
    Default = Boss[1],
    Callback = function(value) _G.FindBoss = value end
})

StackSection:AddButton({
    Title = "🔄 Refresh Boss List",
    Callback = function()
        local liveBosses = {}
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:GetAttribute("IsBoss") and not table.find(liveBosses, obj.Name) then
                table.insert(liveBosses, obj.Name)
            end
        end
        for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("Model") and obj:GetAttribute("IsBoss") and not table.find(liveBosses, obj.Name) then
                table.insert(liveBosses, obj.Name)
            end
        end
        if #liveBosses > 0 then
            table.sort(liveBosses)
            BossDropdown:Refresh(liveBosses, true)
        end
    end
})

StackSection:AddToggle({
    Title = "⚔️ Auto Farm Selected Boss",
    Default = false,
    Callback = function(value) _G.AutoBoss = value end
})

StackSection:AddToggle({
    Title = "📜 Accept Boss Quest",
    Default = false,
    Callback = function(value) _G.AutoAcceptQuest = value end
})

StackSection:AddToggle({
    Title = "⚔️ Farm All Bosses",
    Default = false,
    Callback = function(value) _G.FarmAllBoss = value end
})

