if World1 then table.insert(farmModes, "Tyrant") end
if World2 then table.insert(farmModes, "Factory") end
if World3 then table.insert(farmModes, "Pirate Raid") end

FarmSection = Tabs.Farm:AddSection("Farm Mode")

FarmSection:AddDropdown({
    Title = "📋 Select Mode",
    Values = farmModes,
    Default = GetSetting("SelectedFarmMode_Save", "Level"),
    Callback = function(value)
        _G.SelectedFarmMode = value
        _G.SaveData["SelectedFarmMode_Save"] = value
        SaveSettings()
    end
})

FarmSection:AddToggle({
    Title = "▶️ Start Farming",
    Default = GetSetting("StartFarm_Save", false),
    Callback = function(value)
        _G.StartFarm = value
        _G.Level = false; _G.AutoFarm_Bone = false; _G.AutoFarm_Cake = false
        _G.AutoTyrant = false; _G.AutoFactory = false; _G.AutoRaidCastle = false
        if value then
            if _G.SelectedFarmMode == "Level" then _G.Level = true
            elseif _G.SelectedFarmMode == "Bone" then _G.AutoFarm_Bone = true
            elseif _G.SelectedFarmMode == "Cake Prince" then _G.AutoFarm_Cake = true
            elseif _G.SelectedFarmMode == "Tyrant" then _G.AutoTyrant = true
            elseif _G.SelectedFarmMode == "Factory" then _G.AutoFactory = true
            elseif _G.SelectedFarmMode == "Pirate Raid" then _G.AutoRaidCastle = true end
        end
        _G.SaveData["StartFarm_Save"] = value
        SaveSettings()
    end
})

FarmSection:AddToggle({
    Title = "📜 Auto Accept Quests",
    Default = GetSetting("AcceptQuest_Save", false),
    Callback = function(value)
        _G.AcceptQuest = value
        _G.SaveData["AcceptQuest_Save"] = value
        SaveSettings()
    end
})

