-- Time displays
local TimeLabel = Tabs.Status:AddParagraph({ Title = "🕐 Local Time", Content = "Loading..." })
local GameTimeLabel = Tabs.Status:AddParagraph({ Title = "⏰ Game Time", Content = "Loading..." })

spawn(function()
    while task.wait(1) do
        pcall(function()
            local date = os.date("*t")
            local hour = (date.hour) % 24
            local ampm = hour < 12 and "AM" or "PM"
            local timeStr = string.format("%02d:%02d:%02d %s", ((hour - 1) % 12) + 1, date.min, date.sec, ampm)
            local dateStr = string.format("%02d/%02d/%04d", date.day, date.month, date.year)
            local _, code = pcall(function() return Services.LocalizationService:GetCountryRegionForPlayerAsync(player) end)
            TimeLabel:SetContent(dateStr .. " - " .. timeStr .. " [" .. (code or "Unknown") .. "]")
            
            local gameTime = math.floor(workspace.DistributedGameTime + 0.5)
            local h = math.floor(gameTime / 3600) % 24
            local m = math.floor(gameTime / 60) % 60
            local s = gameTime % 60
            GameTimeLabel:SetContent(string.format("%02d:%02d:%02d", h, m, s))
        end)
    end
end)

-- Island checks
local function CreateIslandCheck(name, checkFunc)
    local label = Tabs.Status:AddParagraph({ Title = name, Content = "❌ Not Found" })
    spawn(function()
        while task.wait(2) do
            pcall(function()
                label:SetContent(checkFunc() and "✅ Found" or "❌ Not Found")
            end)
        end
    end)
end

CreateIslandCheck("Mirage Island", function() return workspace._WorldOrigin.Locations:FindFirstChild("Mirage Island") ~= nil end)
