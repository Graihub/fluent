local PlayerSection = Tabs.Player:AddSection("Movement")

local speedSlider = PlayerSection:AddSlider({
    Title = "🏃 WalkSpeed",
    Range = {16, 250},
    Default = 16,
    Increment = 1,
    Callback = function(value)
        if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            player.Character.Humanoid.WalkSpeed = value
        end
    end
})

local jumpSlider = PlayerSection:AddSlider({
    Title = "🦘 JumpPower",
    Range = {50, 250},
    Default = 50,
    Increment = 1,
    Callback = function(value)
        if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            player.Character.Humanoid.JumpPower = value
        end
    end
})

-- Keep speed/jump values
RunService.Heartbeat:Connect(function()
    if speedSlider.Value and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.WalkSpeed ~= speedSlider.Value then
            hum.WalkSpeed = speedSlider.Value
        end
    end
    if jumpSlider.Value and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.JumpPower ~= jumpSlider.Value then
            hum.JumpPower = jumpSlider.Value
        end
    end
end)

-- Infinity abilities
PlayerSection = Tabs.Player:AddSection("Infinity Abilities")

PlayerSection:AddToggle({
    Title = "♾️ Infinity Energy",
    Default = false,
    Callback = function(value)
        if value then
            player.Character.Energy.Changed:Connect(function()
                player.Character.Energy.Value = player.Character.Energy.MaxValue
            end)
        end
    end
})

