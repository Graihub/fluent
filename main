-- Time display
local TimeLabel = Tabs.Status:AddParagraph({
    Title = "🕐 Local Time",
    Content = "Loading..."
})

local GameTimeLabel = Tabs.Status:AddParagraph({
    Title = "⏰ Game Time",
    Content = "Loading..."
})

-- Update time
spawn(function()
    while task.wait(1) do
        pcall(function()
            local date = os.date("*t")
            local hour = (date.hour) % 24
            local ampm = hour < 12 and "AM" or "PM"
            local timeStr = string.format("%02d:%02d:%02d %s", 
                ((hour - 1) % 12) + 1, date.min, date.sec, ampm)
            local dateStr = string.format("%02d/%02d/%04d", date.day, date.month, date.year)
            
            local _, code = pcall(function()
                return Services.LocalizationService:GetCountryRegionForPlayerAsync(player)
            end)
            
            TimeLabel:SetContent(dateStr .. " - " .. timeStr .. " [" .. (code or "Unknown") .. "]")
            
            local gameTime = math.floor(workspace.DistributedGameTime + 0.5)
            local h = math.floor(gameTime / 3600) % 24
            local m = math.floor(gameTime / 60) % 60
            local s = gameTime % 60
            GameTimeLabel:SetContent(string.format("%02d:%02d:%02d", h, m, s))
        end)
    end
end)

-- Island status
local function CreateIslandStatus(name, checkFunc)
    local label = Tabs.Status:AddParagraph({
        Title = name,
        Content = "❌ Not Found"
    })
    
    spawn(function()
        while task.wait(2) do
            pcall(function()
                local found = checkFunc()
                label:SetContent(found and "✅ Found" or "❌ Not Found")
            end)
        end
    end)
end

CreateIslandStatus("Mirage Island", function()
    return workspace._WorldOrigin.Locations:FindFirstChild("Mirage Island") ~= nil
end)

CreateIslandStatus("Kitsune Island", function()
    return workspace.Map:FindFirstChild("KitsuneIsland") ~= nil
end)

CreateIslandStatus("Prehistoric Island", function()
    return workspace._WorldOrigin.Locations:FindFirstChild("Prehistoric Island") ~= nil
end)

-- Moon phase
local MoonLabel = Tabs.Status:AddParagraph({
    Title = "🌕 Full Moon",
    Content = "Loading..."
})

spawn(function()
    while task.wait(2) do
        pcall(function()
            local moonId = Lighting.Sky and Lighting.Sky.MoonTextureId or ""
            local phase = "0/5"
            if moonId:find("9709149431") then phase = "5/5"
            elseif moonId:find("9709149052") then phase = "4/5"
            elseif moonId:find("9709143733") then phase = "3/5"
            elseif moonId:find("9709150401") then phase = "2/5"
            elseif moonId:find("9709149680") then phase = "1/5"
            end
            MoonLabel:SetContent("Phase: " .. phase)
        end)
    end
end)

